# HDI Prediction System — environment configuration template
# Copy this file to .env and fill in values as needed.
# The app runs fully offline with local models, so these are optional
# extension points (e.g. if you later add authentication or logging).

# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Optional: demo login gate for the hosted evaluator build
APP_DEMO_USERNAME=demo
APP_DEMO_PASSWORD=changeme
